# ── AI Services ──
# DeepSeek API Key (用于 AI 内容生成)
OPENAI_API_KEY=sk-your-deepseek-key
OPENAI_BASE_URL=https://api.deepseek.com/v1

# Anthropic API Key (可选，保留为空使用 DeepSeek)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# ── Dify AI Platform ──
# Dify API 地址 (Docker 内部使用容器名)
DIFY_API_BASE=http://dify-api:5001
# Dify App API 密钥 (Service API, 格式 app-xxx)
DIFY_APP_API_KEY=app-your-app-key
# Dify Console API 访问令牌 (Personal Access Token, 可选)
DIFY_ACCESS_TOKEN=

# ── n8n Workflow Engine ──
# n8n 服务地址 (Docker 内部使用容器名)
N8N_BASE_URL=http://n8n:5678
# n8n API Key (可选，用于认证的 Webhook)
N8N_API_KEY=

# ── Relay Service ──
# AiToEarn Relay API (多平台 OAuth 中继)
RELAY_API_KEY=ak_your-relay-key
RELAY_SERVER_URL=https://aitoearn.cn/api
