@echo off
chcp 65001
cls
echo ======================================================
echo      OpenClaw 自媒体AI助手 Win11 一键安装
echo     热点追踪/内容创作/多平台发布/粉丝互动/数据复盘
echo ======================================================
echo.

echo 正在安装 openclaw & clawhub ...
npm install -g openclaw clawhub
echo.

openclaw onboard --install-daemon
echo.

