# AiBrand Relay Server Configuration

# Server
RELAY_PORT=4011
RELAY_HOST=0.0.0.0

# Encryption key for token storage (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=change-me-generate-with-fernet

# AiBrand main server callback URL
AIBRAND_CALLBACK_URL=http://localhost:8080/api/plat/relay-callback

# Platform OAuth credentials (add per-platform)
# YouTube (Google Cloud Console)
YOUTUBE_CLIENT_ID=your-google-client-id
YOUTUBE_CLIENT_SECRET=your-google-client-secret
YOUTUBE_REDIRECT_URI=http://localhost:4011/api/plat/youtube/callback

# Douyin (抖音开放平台)
DOUYIN_CLIENT_ID=
DOUYIN_CLIENT_SECRET=
DOUYIN_REDIRECT_URI=http://localhost:4011/api/plat/douyin/callback

# Xiaohongshu (小红书开放平台)
XHS_CLIENT_ID=
XHS_CLIENT_SECRET=
XHS_REDIRECT_URI=http://localhost:4011/api/plat/xiaohongshu/callback
