# ============================================================
# AiBrand Server Configuration Template
# ============================================================
# 复制此文件为 .env 并填入真实值。
# .env 文件不应提交到 Git 仓库。

# ── Database ──
MONGODB_URI=mongodb://admin:your-password@localhost:27017/aibrand?authSource=admin&replicaSet=rs0

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# ── Server ──
PORT=3000
NODE_ENV=development

# ── OSS (Aliyun) ──
OSS_REGION=oss-cn-beijing
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=aibrand

# ── JWT ──
# 生成方式: openssl rand -hex 64
JWT_SECRET=your-jwt-secret-at-least-64-chars
JWT_EXPIRES_IN=7d

# ── AI Platform ──
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=

# ── Dify AI 平台 ──
DIFY_API_BASE=http://localhost:5001
DIFY_APP_API_KEY=app-your-dify-app-key
DIFY_ACCESS_TOKEN=

# ── n8n 自动化引擎 ──
N8N_BASE_URL=http://n8n:5678
N8N_API_KEY=

# ── Stripe (optional) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── MyWxPlat ──
MYWXPLAT_APP_ID=dev
MYWXPLAT_APP_SECRET=your-wxplat-secret

# ── NATS (optional) ──
NATS_SERVERS=nats://localhost:4222
