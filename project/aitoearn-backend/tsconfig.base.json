{
  "compileOnSave": false,
  "compilerOptions": {
    "target": "esnext",
    "lib": ["esnext"],
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "baseUrl": ".",
    "rootDir": ".",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "useDefineForClassFields": false,
    "paths": {
      "@yikart/ali-oss": ["libs/ali-oss/src/index.ts"],
      "@yikart/ali-sms": ["libs/ali-sms/src/index.ts"],
      "@yikart/ai-services": ["libs/ai-services/src/index.ts"],
      "@yikart/aibrand-ai-client": ["libs/aibrand-ai-client/src/index.ts"],
      "@yikart/aibrand-auth": ["libs/aibrand-auth/src/index.ts"],
      "@yikart/aibrand-queue": ["libs/aibrand-queue/src/index.ts"],
      "@yikart/assets": ["libs/assets/src/index.ts"],
      "@yikart/aws-s3": ["libs/aws-s3/src/index.ts"],
      "@yikart/common": ["libs/common/src/index.ts"],
      "@yikart/helpers": ["libs/helpers/src/index.ts"],
      "@yikart/mongodb": ["libs/mongodb/src/index.ts"],
      "@yikart/nest-mcp": ["libs/nest-mcp/src/index.ts"],
      "@yikart/redis": ["libs/redis/src/index.ts"],
      "@yikart/redlock": ["libs/redlock/src/index.ts"]
    },
    "strict": true,
    "strictBindCallApply": true,
    "strictNullChecks": true,
    "strictPropertyInitialization": false,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noPropertyAccessFromIndexSignature": true,
    "declaration": false,
    "importHelpers": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipDefaultLibCheck": true,
    "skipLibCheck": true
  },
  "exclude": ["node_modules", "tmp"]
}
