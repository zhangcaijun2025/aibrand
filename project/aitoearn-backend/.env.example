# ============================================================
# AiBrand Server Configuration
# ============================================================
# 复制此文件为 .env 并填入实际值。
# 生产环境中请使用密钥管理服务，不要将 .env 提交到版本控制。

# ── Database ──
MONGODB_USERNAME=admin
MONGODB_PASSWORD=changeme
MONGODB_HOST=localhost
MONGODB_PORT=27017

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme

# ── Server ──
NODE_ENV=development
PORT=3000
APP_DOMAIN=aibrand.local

# ── Assets (Aliyun OSS, JSON string) ──
ASSETS_CONFIG={"region":"oss-cn-beijing","bucket":"your-bucket","endpoint":"oss-cn-beijing.aliyuncs.com","accessKeyId":"","accessKeySecret":""}

# ── JWT ──
# 生成方式: openssl rand -hex 64
JWT_SECRET=changeme-64char-hex
INTERNAL_TOKEN=changeme-internal-token

# ── AI Platform (internal) ──
AI_URL=http://aitoearn-ai:3000

# ── OpenAI (optional) ──
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=

# ── Dify AI 平台 ──
DIFY_API_BASE=http://dify-api-1:5001
DIFY_APP_API_KEY=app-your-app-key
DIFY_ACCESS_TOKEN=

# ── n8n 自动化引擎 ──
N8N_BASE_URL=http://n8n:5678
N8N_API_KEY=

# ── Mail (Amazon SES) ──
MAIL_USER=your-ses-access-key
MAIL_PASS=your-ses-secret-key

# ── SMS (Aliyun) ──
ALI_SMS_ACCESS_KEY_ID=
ALI_SMS_ACCESS_KEY_SECRET=
ALI_SMS_SIGN_NAME=
ALI_SMS_TEMPLATE_CODE=

# ── Platform OAuth (Bilibili) ──
BILIBILI_CLIENT_ID=
BILIBILI_CLIENT_SECRET=

# ── Platform OAuth (Google) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Platform OAuth (Kwai) ──
KWAI_CLIENT_ID=
KWAI_CLIENT_SECRET=

# ── Platform OAuth (Pinterest) ──
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
PINTEREST_TEST_AUTHORIZATION=

# ── Platform OAuth (TikTok) ──
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=

# ── Platform OAuth (Twitter/X) ──
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# ── Platform OAuth (Meta: Facebook + Threads + Instagram + LinkedIn) ──
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_CONFIG_ID=
THREADS_CLIENT_ID=
THREADS_CLIENT_SECRET=
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── Platform OAuth (YouTube) ──
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# ── Platform OAuth (WeChat) ──
WXPLAT_APP_ID=
WXPLAT_APP_SECRET=
WXPLAT_ENCODING_AES_KEY=

# ── Platform OAuth (MyWxPlat) ──
MYWXPLAT_APP_ID=dev
MYWXPLAT_APP_SECRET=changeme

# ── Platform OAuth (Douyin) ──
DOYIN_CLIENT_ID=
DOYIN_CLIENT_SECRET=

# ── OAuth Relay (optional) ──
RELAY_SERVER_URL=
RELAY_API_KEY=
RELAY_CALLBACK_URL=

# ── NATS (optional) ──
NATS_SERVERS=nats://localhost:4222
